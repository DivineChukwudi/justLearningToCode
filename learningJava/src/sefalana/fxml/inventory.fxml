<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sefalana.controller.InventoryController"
      styleClass="root-pane"
      spacing="0">

    <!-- ── Form ─────────────────────────────────────────── -->
    <GridPane styleClass="form-grid" hgap="12" vgap="14">
        <padding><Insets top="30" right="30" bottom="10" left="60"/></padding>

        <Label text="Product Name" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtProductName" styleClass="form-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Category" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <ComboBox fx:id="cmbCategory" styleClass="form-combo" prefWidth="200"
                  GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Price" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="txtPrice" styleClass="form-field"
                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

    <!-- ── Buttons ──────────────────────────────────────── -->
    <HBox styleClass="button-bar" spacing="10" alignment="CENTER_LEFT">
        <padding><Insets top="10" right="0" bottom="10" left="60"/></padding>
        <Button fx:id="btnAdd"    text="Add"    styleClass="btn" onAction="#handleAdd"    prefWidth="80"/>
        <Button fx:id="btnUpdate" text="Update" styleClass="btn" onAction="#handleUpdate" prefWidth="80"/>
        <Button fx:id="btnDelete" text="Delete" styleClass="btn" onAction="#handleDelete" prefWidth="80"/>
    </HBox>

    <!-- ── Table ────────────────────────────────────────── -->
    <VBox styleClass="table-container" VBox.vgrow="ALWAYS">
        <padding><Insets top="10" right="30" bottom="20" left="30"/></padding>
        <TableView fx:id="tableView" styleClass="product-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colName"     text="ProductName" prefWidth="220"/>
                <TableColumn fx:id="colCategory" text="Category"    prefWidth="180"/>
                <TableColumn fx:id="colPrice"    text="Price"       prefWidth="150"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

</VBox>
