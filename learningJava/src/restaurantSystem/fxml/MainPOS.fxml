<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>


<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="restaurantSystem.controllers.MainPOSController"
            prefWidth="1100" prefHeight="720"
            style="-fx-background-color: #1A1A1A;">

   
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="64" spacing="0"
              style="-fx-background-color: #C9A84C;
                     -fx-border-color: #A07830;
                     -fx-border-width: 0 0 2 0;
                     -fx-padding: 0 30 0 30;">

           
            <StackPane fx:id="headerLogoPane" prefWidth="48" prefHeight="48">
                <ImageView fitWidth="48" fitHeight="48" preserveRatio="true">
                    <Image url="@../extras/posLogo.png"/>
                </ImageView>
            </StackPane>

            <Label text="  "/>

            <VBox alignment="CENTER_LEFT" spacing="1">
                <Label text="La Etern"
                       style="-fx-font-family: Georgia; -fx-font-weight: bold;
                              -fx-font-size: 22; -fx-text-fill: #1A1A1A;"/>
                <Label text="Fine Dining  •  Point of Sale"
                       style="-fx-font-family: Georgia; -fx-font-style: italic;
                              -fx-font-size: 11; -fx-text-fill: #3A2800;"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="clockLabel"
                   style="-fx-font-family: 'Courier New'; -fx-font-weight: bold;
                          -fx-font-size: 13; -fx-text-fill: #1A1A1A;"/>
        </HBox>
    </top>


    <center>
        <HBox spacing="0">
            <!-- LEFT MENU PANEL -->
            <ScrollPane fitToWidth="true" prefWidth="500"
                       style="-fx-background-color: #1A1A1A;
                              -fx-padding: 0;
                              -fx-border-color: #333333;
                              -fx-border-width: 0 1 0 0;">
                <VBox fx:id="orderPanel" spacing="20" prefWidth="480"
                      style="-fx-background-color: #1A1A1A;
                             -fx-padding: 20 20 20 20;">

                    <!-- DINNER SECTION -->
                    <VBox spacing="12">
                        <Label text="🍖  DINNER SELECTIONS"
                               style="-fx-font-family: Georgia; -fx-font-weight: bold;
                                      -fx-font-size: 13; -fx-text-fill: #C9A84C;
                                      -fx-padding: 0 0 5 0;
                                      -fx-border-color: #C9A84C;
                                      -fx-border-width: 0 0 1 0;"/>
                        <VBox fx:id="dinnerBox" spacing="10">
                            <HBox spacing="12" alignment="TOP_LEFT" style="-fx-background-color: #252525; -fx-padding: 10; -fx-border-radius: 4;">
                                <ImageView fitHeight="65" fitWidth="65" preserveRatio="true">
                                    <image><Image url="@../extras/beefTenderloin.webp"/></image>
                                </ImageView>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <CheckBox text="Beef Tenderloin" style="-fx-text-fill: #DDDDDD; -fx-font-weight: bold;" onAction="#onSelectionChange"/>
                                    <Label text="M 85.00" style="-fx-text-fill: #C9A84C; -fx-font-weight: bold; -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="12" alignment="TOP_LEFT" style="-fx-background-color: #252525; -fx-padding: 10; -fx-border-radius: 4;">
                                <ImageView fitHeight="65" fitWidth="65" preserveRatio="true">
                                    <image><Image url="@../extras/chickenSupreme.webp"/></image>
                                </ImageView>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <CheckBox text="Chicken Supreme" style="-fx-text-fill: #DDDDDD; -fx-font-weight: bold;" onAction="#onSelectionChange"/>
                                    <Label text="M 65.00" style="-fx-text-fill: #C9A84C; -fx-font-weight: bold; -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="12" alignment="TOP_LEFT" style="-fx-background-color: #252525; -fx-padding: 10; -fx-border-radius: 4;">
                                <ImageView fitHeight="65" fitWidth="65" preserveRatio="true">
                                    <image><Image url="@../extras/grilledSalmon.webp"/></image>
                                </ImageView>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <CheckBox text="Grilled Salmon" style="-fx-text-fill: #DDDDDD; -fx-font-weight: bold;" onAction="#onSelectionChange"/>
                                    <Label text="M 75.00" style="-fx-text-fill: #C9A84C; -fx-font-weight: bold; -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="12" alignment="TOP_LEFT" style="-fx-background-color: #252525; -fx-padding: 10; -fx-border-radius: 4;">
                                <ImageView fitHeight="65" fitWidth="65" preserveRatio="true">
                                    <image><Image url="@../extras/rackOfLamb.webp"/></image>
                                </ImageView>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <CheckBox text="Rack of Lamb" style="-fx-text-fill: #DDDDDD; -fx-font-weight: bold;" onAction="#onSelectionChange"/>
                                    <Label text="M 95.00" style="-fx-text-fill: #C9A84C; -fx-font-weight: bold; -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="12" alignment="TOP_LEFT" style="-fx-background-color: #252525; -fx-padding: 10; -fx-border-radius: 4;">
                                <ImageView fitHeight="65" fitWidth="65" preserveRatio="true">
                                    <image><Image url="@../extras/vegetableRisotto.webp"/></image>
                                </ImageView>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <CheckBox text="Vegetable Risotto" style="-fx-text-fill: #DDDDDD; -fx-font-weight: bold;" onAction="#onSelectionChange"/>
                                    <Label text="M 45.00" style="-fx-text-fill: #C9A84C; -fx-font-weight: bold; -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- DESSERT SECTION -->
                    <VBox spacing="12">
                        <Label text="🍰  DESSERT SELECTIONS"
                               style="-fx-font-family: Georgia; -fx-font-weight: bold;
                                      -fx-font-size: 13; -fx-text-fill: #C9A84C;
                                      -fx-padding: 0 0 5 0;
                                      -fx-border-color: #C9A84C;
                                      -fx-border-width: 0 0 1 0;"/>
                        <VBox fx:id="dessertBox" spacing="10">
                            <HBox spacing="12" alignment="TOP_LEFT" style="-fx-background-color: #252525; -fx-padding: 10; -fx-border-radius: 4;">
                                <ImageView fitHeight="65" fitWidth="65" preserveRatio="true">
                                    <image><Image url="@../extras/cheeseCake.webp"/></image>
                                </ImageView>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <RadioButton text="Cheese Cake" style="-fx-text-fill: #DDDDDD; -fx-font-weight: bold;" onAction="#onSelectionChange"/>
                                    <Label text="M 28.00" style="-fx-text-fill: #C9A84C; -fx-font-weight: bold; -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="12" alignment="TOP_LEFT" style="-fx-background-color: #252525; -fx-padding: 10; -fx-border-radius: 4;">
                                <ImageView fitHeight="65" fitWidth="65" preserveRatio="true">
                                    <image><Image url="@../extras/chocolateFondant.webp"/></image>
                                </ImageView>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <RadioButton text="Chocolate Fondant" style="-fx-text-fill: #DDDDDD; -fx-font-weight: bold;" onAction="#onSelectionChange"/>
                                    <Label text="M 32.00" style="-fx-text-fill: #C9A84C; -fx-font-weight: bold; -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="12" alignment="TOP_LEFT" style="-fx-background-color: #252525; -fx-padding: 10; -fx-border-radius: 4;">
                                <ImageView fitHeight="65" fitWidth="65" preserveRatio="true">
                                    <image><Image url="@../extras/cremeBrulee.webp"/></image>
                                </ImageView>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <RadioButton text="Creme Brulee" style="-fx-text-fill: #DDDDDD; -fx-font-weight: bold;" onAction="#onSelectionChange"/>
                                    <Label text="M 26.00" style="-fx-text-fill: #C9A84C; -fx-font-weight: bold; -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="12" alignment="TOP_LEFT" style="-fx-background-color: #252525; -fx-padding: 10; -fx-border-radius: 4;">
                                <ImageView fitHeight="65" fitWidth="65" preserveRatio="true">
                                    <image><Image url="@../extras/fruitSorbet.webp"/></image>
                                </ImageView>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <RadioButton text="Fruit Sorbet" style="-fx-text-fill: #DDDDDD; -fx-font-weight: bold;" onAction="#onSelectionChange"/>
                                    <Label text="M 18.00" style="-fx-text-fill: #C9A84C; -fx-font-weight: bold; -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="12" alignment="TOP_LEFT" style="-fx-background-color: #252525; -fx-padding: 10; -fx-border-radius: 4;">
                                <ImageView fitHeight="65" fitWidth="65" preserveRatio="true">
                                    <image><Image url="@../extras/tiramisu.webp"/></image>
                                </ImageView>
                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                    <RadioButton text="Tiramisu" style="-fx-text-fill: #DDDDDD; -fx-font-weight: bold;" onAction="#onSelectionChange"/>
                                    <Label text="M 24.00" style="-fx-text-fill: #C9A84C; -fx-font-weight: bold; -fx-font-size: 11;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- DRINKS SECTION -->
                    <VBox spacing="12">
                        <Label text="🥤  BEVERAGES"
                               style="-fx-font-family: Georgia; -fx-font-weight: bold;
                                      -fx-font-size: 13; -fx-text-fill: #C9A84C;
                                      -fx-padding: 0 0 5 0;
                                      -fx-border-color: #C9A84C;
                                      -fx-border-width: 0 0 1 0;"/>
                        <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-background-color: #252525; -fx-padding: 12; -fx-border-radius: 4;">
                            <ImageView fitHeight="70" fitWidth="70" preserveRatio="true">
                                <image><Image url="@../extras/drinksVariety.webp"/></image>
                            </ImageView>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <ComboBox fx:id="drinksCombo" prefWidth="280"
                                          styleClass="menu-combo"
                                          onAction="#onSelectionChange"
                                          style="-fx-background-color: #1A1A1A; -fx-text-fill: #DDDDDD;"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="Quantity:" style="-fx-text-fill: #888888; -fx-font-size: 11;"/>
                                    <Spinner fx:id="drinkQtySpinner" prefWidth="70"
                                             style="-fx-background-color: #1A1A1A;
                                                    -fx-border-color: #444444;
                                                    -fx-border-width: 0 0 1.5 0;"/>
                                </HBox>
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- PAYMENT SECTION -->
                    <VBox spacing="10" style="-fx-background-color: #2A2A2A; -fx-padding: 15; -fx-border-radius: 4;">
                        <Label text="💰  CASH PAYMENT"
                               style="-fx-font-family: Georgia; -fx-font-weight: bold;
                                      -fx-font-size: 12; -fx-text-fill: #C9A84C;"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="M" style="-fx-font-family: Georgia; -fx-font-weight: bold;
                                                   -fx-font-size: 16; -fx-text-fill: #C9A84C;"/>
                            <TextField fx:id="cashField"
                                       promptText="Enter amount paid"
                                       prefHeight="32"
                                       style="-fx-background-color: #1A1A1A;
                                              -fx-text-fill: #DDDDDD;
                                              -fx-padding: 8;
                                              -fx-font-size: 12;
                                              -fx-border-color: #444444;
                                              -fx-border-width: 0 0 1.5 0;"/>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>

            <!-- RIGHT ORDER PANEL -->
            <VBox HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #1E1E1E;">

                <HBox style="-fx-background-color: #2A2A2A;
                             -fx-border-color: #333;
                             -fx-border-width: 0 0 2 0;
                             -fx-padding: 14 20 14 20;">
                    <Label text="📋 LIVE ORDER SUMMARY"
                           style="-fx-font-family: Georgia; -fx-font-weight: bold;
                                  -fx-font-size: 14; -fx-text-fill: #C9A84C;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Items update as selections are made"
                           style="-fx-font-family: Arial; -fx-font-style: italic;
                                  -fx-font-size: 10; -fx-text-fill: #888888;"/>
                </HBox>

                <TableView fx:id="orderTable" VBox.vgrow="ALWAYS"
                           styleClass="order-table"
                           style="-fx-background-color: #1E1E1E; -fx-border-color: #333; -fx-border-width: 0;"/>

                <VBox spacing="10"
                      style="-fx-background-color: #222222;
                             -fx-border-color: #C9A84C;
                             -fx-border-width: 2 0 0 0;
                             -fx-padding: 18 20 18 20;">
                    <HBox alignment="CENTER_RIGHT" spacing="20">
                        <Label text="ORDER TOTAL:"
                               style="-fx-font-family: Georgia; -fx-font-weight: bold;
                                      -fx-font-size: 13; -fx-text-fill: #C9A84C;"/>
                        <Label fx:id="totalLabel" text="M 0.00"
                               style="-fx-font-family: 'Courier New'; -fx-font-weight: bold;
                                      -fx-font-size: 16; -fx-text-fill: #FFFFFF;"/>
                    </HBox>
                    <Separator style="-fx-border-color: #444444;"/>
                    <HBox alignment="CENTER_RIGHT" spacing="20">
                        <Label text="CHANGE:"
                               style="-fx-font-family: Georgia; -fx-font-weight: bold;
                                      -fx-font-size: 13; -fx-text-fill: #6FCF97;"/>
                        <Label fx:id="changeLabel" text="M 0.00"
                               style="-fx-font-family: 'Courier New'; -fx-font-weight: bold;
                                      -fx-font-size: 16; -fx-text-fill: #6FCF97;"/>
                    </HBox>
                </VBox>

            </VBox>
        </HBox>
    </center>

    
    <bottom>
        <HBox spacing="12" alignment="CENTER"
              style="-fx-background-color: #1A1A1A;
                     -fx-border-color: #C9A84C;
                     -fx-border-width: 1 0 0 0;
                     -fx-padding: 14 30 14 30;">

            <Button fx:id="saleBtn"
                    text="✔   COMPLETE SALE"
                    prefHeight="42" minWidth="160"
                    onAction="#handleCompleteSale"
                    style="-fx-background-color: #C9A84C; -fx-text-fill: #1A1A1A;
                           -fx-font-weight: bold; -fx-font-size: 12;
                           -fx-background-radius: 2; -fx-cursor: hand;"/>

            <Button fx:id="resetBtn"
                    text="↺   RESET"
                    prefHeight="42" minWidth="160"
                    onAction="#handleReset"
                    style="-fx-background-color: #3A3A3A; -fx-text-fill: #BBBBBB;
                           -fx-font-weight: bold; -fx-font-size: 12;
                           -fx-background-radius: 2; -fx-cursor: hand;"/>

            <Button fx:id="viewBtn"
                    text="📄  VIEW RECEIPTS"
                    prefHeight="42" minWidth="160"
                    onAction="#handleViewReceipts"
                    style="-fx-background-color: #1E3A5F; -fx-text-fill: #CCCCCC;
                           -fx-font-weight: bold; -fx-font-size: 12;
                           -fx-background-radius: 2; -fx-cursor: hand;"/>

            <Button fx:id="exitBtn"
                    text="✕   EXIT"
                    prefHeight="42" minWidth="160"
                    onAction="#handleExit"
                    style="-fx-background-color: #5C2020; -fx-text-fill: #CCCCCC;
                           -fx-font-weight: bold; -fx-font-size: 12;
                           -fx-background-radius: 2; -fx-cursor: hand;"/>
        </HBox>
    </bottom>

</BorderPane>
