<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>



<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="restaurantSystem.controllers.LoginController"
           prefWidth="820" prefHeight="600"
           style="-fx-background-color: #1A1A1A;">

    
    <Rectangle fx:id="topBar"
               width="820" height="4"
               fill="#C9A84C"
               StackPane.alignment="TOP_CENTER"/>

    
    <Rectangle fx:id="bottomBar"
               width="820" height="4"
               fill="#C9A84C"
               StackPane.alignment="BOTTOM_CENTER"/>

    
    <VBox fx:id="loginCard"
          alignment="CENTER" spacing="14"
          maxWidth="400" maxHeight="500"
          style="-fx-background-color: #232323;
                 -fx-border-color: #C9A84C;
                 -fx-border-width: 1.5;
                 -fx-border-radius: 4;
                 -fx-background-radius: 4;
                 -fx-padding: 40 50 40 50;">

      
        <StackPane fx:id="logoPane" prefWidth="120" prefHeight="120"
                   StackPane.alignment="CENTER">
            <ImageView fx:id="logoImage" fitWidth="120" fitHeight="120" preserveRatio="true">
                <Image url="@../extras/posLogo.png"/>
            </ImageView>
        </StackPane>

        
        <Label text="LA ETERN"
               style="-fx-font-family: Georgia;
                      -fx-font-weight: bold;
                      -fx-font-size: 30;
                      -fx-text-fill: #C9A84C;"/>

        
        <Label text="Exclusive Eatery &amp; Bistro"
               style="-fx-font-family: Georgia;
                      -fx-font-style: italic;
                      -fx-font-size: 13;
                      -fx-text-fill: #888888;"/>

       
        <Separator style="-fx-border-color: #C9A84C; -fx-opacity: 0.5;"/>

        
        <Label text="USERNAME"
               style="-fx-font-family: Arial;
                      -fx-font-weight: bold;
                      -fx-font-size: 10;
                      -fx-text-fill: #C9A84C;"/>
        <TextField fx:id="usernameField"
                   promptText="Enter username"
                   styleClass="login-field"/>

        
        <Label text="PASSWORD"
               style="-fx-font-family: Arial;
                      -fx-font-weight: bold;
                      -fx-font-size: 10;
                      -fx-text-fill: #C9A84C;"/>
        <PasswordField fx:id="passwordField"
                       promptText="Enter password"
                       styleClass="login-field"
                       onAction="#handleLogin"/>

        
        <Label fx:id="errorLabel" text=""
               style="-fx-text-fill: #CF6679; -fx-font-size: 11;"/>

        <!-- Sign in button -->
        <Button fx:id="loginBtn"
                text="SIGN IN"
                prefWidth="300" prefHeight="42"
                styleClass="login-btn"
                onAction="#handleLogin"/>

    </VBox>

</StackPane>
